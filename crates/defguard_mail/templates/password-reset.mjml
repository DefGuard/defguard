{% import "macros.mjml" as macros %}
{% extends "base.mjml" %}
{% block content %}

{{ macros::email_header() }}

<mj-section>
  <mj-column mj-class="s-3xl">
    <mj-text>
      <p>
        <a href="{{ link_url }}" target="_blank">{{ link_url }}</a>
      </p>
    </mj-text>
  </mj-column>
</mj-section>

{{ macros::footer_divider() }}

{% endblock content %}
