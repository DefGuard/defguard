{
  "db_name": "PostgreSQL",
  "query": "SELECT g.id, g.location_id, g.name, g.address, g.port, g.connected_at, g.disconnected_at, CASE WHEN g.connected_at IS NULL THEN false WHEN g.disconnected_at IS NULL THEN true WHEN g.connected_at >= g.disconnected_at THEN true ELSE false END AS \"connected!\", g.certificate_serial, g.certificate_expiry, g.version, g.enabled, g.modified_at, g.modified_by, wn.name AS location_name FROM gateway g JOIN wireguard_network wn ON g.location_id = wn.id WHERE location_id = $1",
